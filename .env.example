# ============================================================
# WelzijnsEvent.nl — Omgevingsvariabelen
# Kopieer dit bestand naar .env.local en vul de waarden in
# ============================================================

# Neon Database (https://neon.tech)
# Maak een project aan → Connection Details → Connection string
DATABASE_URL=postgres://[user]:[password]@[host]/[dbname]?sslmode=require

# Clerk Auth (https://clerk.com)
# Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Pusher (https://pusher.com) — voor live Q&A en polls
# Dashboard → App Keys
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=eu
NEXT_PUBLIC_PUSHER_KEY=your_key
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenRouter (https://openrouter.ai) — voor AI-matching
# Dashboard → Keys → Create key
OPENROUTER_API_KEY=sk-or-v1-...
# Optioneel: overschrijf het AI-model (standaard: google/gemini-2.0-flash-001)
# Aanbevolen alternatieven: anthropic/claude-3.5-sonnet, openai/gpt-4o
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Resend (https://resend.com) — voor bevestigingsmails
# Dashboard → API Keys → Create API key
RESEND_API_KEY=re_...

# MultiSafePay (optioneel, voor betaalde tickets)
MULTISAFEPAY_API_KEY=
MULTISAFEPAY_ENV=test

# Web Push / VAPID (https://web.dev/push-notifications-web-push-protocol/)
# Genereer eenmalig met: npx web-push generate-vapid-keys
# NEXT_PUBLIC_ prefix zodat de publieke key beschikbaar is in de browser
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=info@bijeen.app
