# ============================================================
# WelzijnsEvent.nl — Omgevingsvariabelen
# Kopieer dit bestand naar .env.local en vul de waarden in
# ============================================================

# Neon Database (https://neon.tech)
# Maak een project aan → Connection Details → Connection string
DATABASE_URL=postgres://[user]:[password]@[host]/[dbname]?sslmode=require

# Clerk Auth (https://clerk.com)
# Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Pusher (https://pusher.com) — voor live Q&A en polls
# Dashboard → App Keys
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=eu
NEXT_PUBLIC_PUSHER_KEY=your_key
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenRouter (https://openrouter.ai) — voor AI-matching
# Dashboard → Keys → Create key
OPENROUTER_API_KEY=sk-or-v1-...
# Optioneel: overschrijf het AI-model (standaard: google/gemini-2.5-flash)
# Aanbevolen alternatieven: google/gemini-3.5-flash, anthropic/claude-3.5-sonnet, openai/gpt-4o
OPENROUTER_MODEL=google/gemini-2.5-flash

# Resend (https://resend.com) — voor bevestigingsmails
# Dashboard → API Keys → Create API key
RESEND_API_KEY=re_...

# Stripe (https://dashboard.stripe.com/apikeys)
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Dashboard → Developers → Webhooks → Add endpoint → /api/payments/stripe/webhook
# Events: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# Web Push / VAPID (https://web.dev/push-notifications-web-push-protocol/)
# Genereer eenmalig met: npx web-push generate-vapid-keys
# NEXT_PUBLIC_ prefix zodat de publieke key beschikbaar is in de browser
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=info@bijeen.app

# ── SEO Indexering ────────────────────────────────────────────
# IndexNow (gratis, ondersteund door Bing/Yandex/Google)
# Genereer een willekeurige key: openssl rand -hex 16
# Na instelling is de verificatie-URL: /api/indexnow-key
INDEXNOW_KEY=

# Google Indexing API via Service Account
# Stap 1: Ga naar https://console.cloud.google.com → maak project → activeer "Indexing API"
# Stap 2: IAM & Admin → Service Accounts → maak aan → download JSON-sleutel
# Stap 3: Voeg het e-mailadres van de service account toe als "Eigenaar" in Google Search Console
# Plak de inhoud van het JSON-bestand als één regel (zonder newlines) in GOOGLE_SERVICE_ACCOUNT_JSON
GOOGLE_SERVICE_ACCOUNT_JSON=

# Publieke app URL (voor SEO-indexering en OpenGraph)
NEXT_PUBLIC_APP_URL=https://bijeen.app

# ── Demo toegang ──────────────────────────────────────────────
# Tijdelijke toegangscode voor demo-sessies
DEMO_CODE=DEMO2024
DEMO_EXPIRES=2024-12-31T23:59:59Z
# Sandbox e-mailadres voor de demo-gebruiker (NOOIT een echte gebruiker!)
DEMO_USER_EMAIL=demo@bijeen.app

# ── Admin credentials ──────────────────────────────────────────
# Genereer hash met: node -e "require('bcryptjs').hash('wachtwoord',12).then(console.log)"
ADMIN_EMAIL=admin@bijeen.app
ADMIN_PASSWORD_HASH=
